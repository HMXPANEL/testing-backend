# App Settings
APP_NAME="AI Agent Brain"
APP_VERSION="1.0.0"
DEBUG=True

# NVIDIA LLM Settings
NVIDIA_API_KEY="your_nvidia_api_key"
NVIDIA_BASE_URL="https://integrate.api.nvidia.com/v1"
NVIDIA_MODEL_NAME="meta/llama3-70b-instruct"

# Android WebSocket Secret
ANDROID_WEBSOCKET_SECRET="your_android_secret_key"

# Database Settings
SQLITE_DB_PATH="./data/memory.db"
CHROMA_DB_PATH="./data/chroma_db"

# Agent Settings
MAX_AGENT_ITERATIONS=15
AGENT_LOOP_INTERVAL_SEC=1
